<!DOCTYPE html>
<html>
  <head>
    <title>Catch the Square Game</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        text-align: center;
        margin: 0;
        height: 100vh;
        background-color: #f0f0f0;
        overflow: hidden;
      }
      h1 {
        margin-top: 20px;
      }
      #game-area {
        position: relative;
        width: 100%;
        height: 80vh;
        border: 2px solid #333;
        background: linear-gradient(135deg, #92A8D1, #F7CAC9);
      }
      #square {
        width: 50px;
        height: 50px;
        background-color: #FF6F61;
        position: absolute;
        border-radius: 8px;
        animation: bounce 3s infinite alternate;
        cursor: pointer;
      }
      @keyframes bounce {
        0% { top: 10%; left: 10%; }
        25% { top: 70%; left: 20%; }
        50% { top: 40%; left: 80%; }
        75% { top: 60%; left: 50%; }
        100% { top: 20%; left: 70%; }
      }
    </style>
  </head>
  <body>
    <h1>Catch the Square 🎮</h1>
    <p>Click the moving square to score points!</p>
    <div id="game-area">
      <div id="square"></div>
    </div>
    <p id="score">Score: 0</p>

    <script>
      let score = 0;
      const square = document.getElementById("square");
      const scoreDisplay = document.getElementById("score");

      square.addEventListener("click", () => {
        score++;
        scoreDisplay.textContent = "Score: " + score;
        // Randomize color for fun
        const colors = ["#FF6F61", "#6B5B95", "#88B04B", "#F7CAC9", "#92A8D1"];
        square.style.backgroundColor =
          colors[Math.floor(Math.random() * colors.length)];
      });
    </script>
  </body>
</html>

